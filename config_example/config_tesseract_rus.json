{
    "default_target": "en",
    
    "ocr_provider": "tesseract",
    "translation_provider": "groq",
    "tts_provider": "google",
    
    "local_server_ocr_processor": {
        "source_lang": "rus",
        "psm_mode": 3,
        "min_pixels": 5,
        "pipeline": [
            {
                "action": "reduceToMultiColor",
                "options": {
                    "base": "000000",
                    "colors": [
                        ["FFFFFF", "FFFFFF"]
                    ],
                    "threshold": 16
                }
            },
            {
                "action": "segFill",
                "options": {
                    "base": "000000",
                    "color": "FFFFFF"
                }
            }
        ]
    },
    
    "groq_api_key": "YOUR_GROQ_API_KEY_HERE",
    "groq_base_url": "https://api.groq.com/openai/v1",
    "groq_model": "llama-3.1-70b-versatile",
    
    "use_bbox_fallback": false,
    
    "local_server_host": "0.0.0.0",
    "local_server_port": 4404,
    "local_server_enabled": true
}
