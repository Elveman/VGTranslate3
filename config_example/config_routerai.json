{
    "default_target": "en",
    
    "ocr_provider": "openai",
    "ocr_model": "openai/gpt-4o-mini",
    
    "translation_provider": "openai",
    "translation_model": "anthropic/claude-3.5-haiku",
    
    "tts_provider": "google",
    
    "openai_api_key": "ra_YOUR_ROUTERAI_API_KEY_HERE",
    "openai_base_url": "https://routerai.ru/api/v1",
    
    "use_bbox_fallback": true,
    "openai_timeout": 30,
    "openai_max_retries": 3,
    
    "local_server_host": "0.0.0.0",
    "local_server_port": 4404,
    "local_server_enabled": true
}
